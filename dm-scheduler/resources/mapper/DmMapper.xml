<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dm.mapper.DmMapper">
    <resultMap id="dmMap" type="com.example.dm.entity.Dm">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="dm_level" property="dmLevel"/>
        <result column="experience" property="experience"/>
        <result column="rating" property="rating"/>
    </resultMap>
    
    <select id="selectById" resultMap="dmMap">
        SELECT * FROM dm WHERE id = #{id}
    </select>
    
    <select id="selectByUserId" resultMap="dmMap">
        SELECT * FROM dm WHERE user_id = #{userId}
    </select>
    
    <select id="selectAll" resultMap="dmMap">
        SELECT * FROM dm
    </select>
    
    <select id="selectByLevel" resultMap="dmMap">
        SELECT * FROM dm WHERE dm_level >= #{level}
    </select>
    
    <insert id="insert" parameterType="com.example.dm.entity.Dm">
        INSERT INTO dm(user_id, dm_level, experience, rating)
        VALUES(#{userId}, #{dmLevel}, #{experience}, #{rating})
    </insert>
    
    <update id="update" parameterType="com.example.dm.entity.Dm">
        UPDATE dm
        SET user_id = #{userId}, dm_level = #{dmLevel}, experience = #{experience}, rating = #{rating}
        WHERE id = #{id}
    </update>
    
    <delete id="delete" parameterType="java.lang.Integer">
        DELETE FROM dm WHERE id = #{id}
    </delete>
</mapper>