<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dm.mapper.OperationLogMapper">
    <resultMap id="logMap" type="com.example.dm.entity.OperationLog">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="action" property="action"/>
        <result column="target" property="target"/>
        <result column="detail" property="detail"/>
        <result column="ip" property="ip"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="selectAll" resultMap="logMap">
        SELECT * FROM operation_log ORDER BY created_at DESC
    </select>

    <!-- 分页查询 -->
    <select id="selectPage" resultMap="logMap">
        SELECT * FROM operation_log
        <where>
            <if test="action != null and action != ''">
                AND action = #{action}
            </if>
            <if test="target != null and target != ''">
                AND target = #{target}
            </if>
            <if test="startDate != null and startDate != ''">
                AND created_at >= #{startDate}
            </if>
            <if test="endDate != null and endDate != ''">
                AND created_at &lt;= #{endDate}
            </if>
        </where>
        ORDER BY created_at DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <!-- 统计满足条件的记录数 -->
    <select id="countByCondition" resultType="java.lang.Long">
        SELECT COUNT(*) FROM operation_log
        <where>
            <if test="action != null and action != ''">
                AND action = #{action}
            </if>
            <if test="target != null and target != ''">
                AND target = #{target}
            </if>
            <if test="startDate != null and startDate != ''">
                AND created_at >= #{startDate}
            </if>
            <if test="endDate != null and endDate != ''">
                AND created_at &lt;= #{endDate}
            </if>
        </where>
    </select>

    <insert id="insert" parameterType="com.example.dm.entity.OperationLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO operation_log(user_id, action, target, detail, ip)
        VALUES(#{userId}, #{action}, #{target}, #{detail}, #{ip})
    </insert>
</mapper>
